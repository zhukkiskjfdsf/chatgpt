class Tee:
    """同时输出到终端和日志文件。"""

    def __init__(self, stream: Any, logfile: Any):
        self.stream = stream
        self.logfile = logfile

    def write(self, data: str) -> None:
        self.stream.write(data)
        self.logfile.write(data)

    def flush(self) -> None:
        self.stream.flush()
        self.logfile.flush()


